<cit source="https://uhh-tamilex.github.io/Narrinai/NA245.xml?id=NA245&amp;w=22,26">
    <q xml:lang="ta"><w><c type="glide">y</c>oḻuku</w> <w>nuṇ</w> <w>nucuppiṉ</w> <w>akaṉṟa</w> <w><c type="glide">v</c>alkul</w></q>
    <q xml:lang="en">with a narrow waist and wide hips</q>
    <ref target="https://uhh-tamilex.github.io/Narrinai/NA245.xml?highlight=%5Bid%3DNA245%5D%20.l%3Anth-of-type(5)">NA245, line 5</ref>
</cit>

<note xml:lang="en">
</note></sense><sense><def xml:lang="en">buttocks
</def>
<usg xml:lang="en">
</usg>
<cit source="https://uhh-tamilex.github.io/Paripatal/Pari13.xml?id=Pari13&amp;w=288,291">
    <q xml:lang="ta"><w>mārp<c type="elided">u</c>-um</w> <w>alkul-um</w> <w>maṉattoṭu</w> <w>periyai</w></q>
    <q xml:lang="en">you (Tirumāl, m.sg.!) are big in chest and buttocks, along with the mind</q>
