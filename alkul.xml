      <entry corresp="alkul[DEDR253]">
        <form xml:lang="ta">alkul</form>
        <gramGrp><gram>noun</gram></gramGrp>
        <sense><def xml:lang="en">hip</def>
<usg xml:lang="en">
</usg>
<cit source="https://uhh-tamilex.github.io/Kuruntokai/KT345.xml?id=KT345&amp;w=17,21">
    <q xml:lang="ta"><w>taḻai</w> <w>tāḻ</w> <w>alkul</w> <w>ivaḷ</w> <w>pulamp<c type="elided">u</c></w></q>
    <q xml:lang="en">she with hips from which a leaf [skirt] hangs down</q>
    <ref target="https://uhh-tamilex.github.io/Kuruntokai/KT345.xml?highlight=%5Bid%3DKT345%5D%20.l%3Anth-of-type(4)">KT345, line 4</ref>
</cit>
<cit source="https://uhh-tamilex.github.io/Kuruntokai/KT101.xml?id=KT101&amp;w=22,26">
    <q xml:lang="ta"><w>māṇ</w> <w>vari</w> <w><c type="glide">y</c>alkul</w> <w>kuṟu</w> <w>makaḷ</w></q>
    <q xml:lang="en">small woman with hips of glorious outline</q>
    <ref target="https://uhh-tamilex.github.io/Kuruntokai/KT101.xml?highlight=%5Bid%3DKT101%5D%20.l%3Anth-of-type(5)">KT101, line 5</ref>
