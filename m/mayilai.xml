                </cit>
            </sense>
        </cit>
        <cit type="nikantu" xml:id="Tiv3.191">
            <ref target="https://archive.org/details/20240820_20240820_1903/page/188/mode/2up"><title xml:lang="ta">Tivākaram</title> 3.191 <term xml:lang="ta">mīṉ potuppeyar</term></ref>
            <q rend="block" xml:lang="ta">
                <lg>
                    <l>mīṉamum, maccamum, mayilaiyum, mīṉ peyar.</l>
                </lg>
            </q>
        </cit>
        <cit type="nikantu" xml:id="Tiv4.170">
          <ref target="https://archive.org/details/20240820_20240820_1903/page/244/mode/1up"><title xml:lang="ta">Tivākaram</title> 4.170 <term xml:lang="ta">iruvāṭciyiṉ peyar</term></ref>
            <q rend="block" xml:lang="ta">
                <lg>
                  <l>mayilai yiruvāṭci yāku meṉpa.</l>
                </lg>
            </q>
        </cit>
        <cit type="nikantu" xml:id="Pink8.317">
          <ref target="https://archive.org/details/dli.jZY9lup2kZl6TuXGlZQdjZp7kZUy.TVA_BOK_0002448/page/264/mode/1up"><title xml:lang="ta">Piṅkalam</title> 8.317 <term xml:lang="ta">mīṉ potup peyar</term></ref>
            <q rend="block" xml:lang="ta">
                <lg>
              <l>mayilaiyum, māṉum, maccamum, mīṉamum,</l>
              <l>puḻalum, mīṉiṉ potup peyar (ākum).</l>
                </lg>
            </q>
        </cit>
        <cit type="nikantu" xml:id="Pink9.297">
          <ref target="https://archive.org/details/dli.jZY9lup2kZl6TuXGlZQdjZp7kZUy.TVA_BOK_0002448/page/276/mode/1up"><title xml:lang="ta">Piṅkalam</title> 9.297 <term xml:lang="ta">iruvāṭci</term></ref>
            <q rend="block" xml:lang="ta">
                <lg>
              <l>mayilai, aṉaṅkam, iruvāṭci.</l>
                </lg>
            </q>
        </cit>
        <cit type="nikantu" xml:id="Pink10.902">
          <ref target="https://archive.org/details/dli.jZY9lup2kZl6TuXGlZQdjZp7kZUy.TVA_BOK_0002448/page/320/mode/1up"><title xml:lang="ta">Piṅkalam</title> 10.902 <term xml:lang="ta">mayilai</term></ref>
            <q rend="block" xml:lang="ta">
                <lg>
              <l>mīṉiṉ potuvum, mīṉa irāciyum,</l>
              <l>(malar) iruvāṭciyum, mayilai (ākum).</l>
                </lg>
            </q>
        </cit>
