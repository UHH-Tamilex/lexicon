      <entry corresp="iḻutu[DEDR5299(b)]">
        <form xml:lang="ta">iḻutu</form>
        <gramGrp><gram>noun</gram></gramGrp>
        <sense><def xml:lang="en">fat</def>
<usg xml:lang="en">
</usg>
<cit source="https://uhh-tamilex.github.io/Purananuru/PN281.xml?id=PN281&amp;w=15,17">
    <q xml:lang="ta"><w>mai</w> <w><c type="glide">y</c>iḻut<c type="elided">u</c></w> <w>iḻuki</w></q>
    <q xml:lang="en">smearing with kajal[-dark]/goat fat</q>
    <ref target="https://uhh-tamilex.github.io/Purananuru/PN281.xml?highlight=%5Bid%3DPN281%5D%20.l%3Anth-of-type(3)"><expan ref="#PN"/> 281, line 3</ref>
</cit>
<cit source="https://uhh-tamilex.github.io/Purananuru/PN325.xml?id=PN325&amp;w=34,36">
    <q xml:lang="ta"><w>uṭump<c type="elided">u</c></w> <w>iḻut<c type="elided">u</c></w> <w>aṟutta</w></q>
    <q xml:lang="en">who cut of the fat of the iguana</q>
            <ref target="https://uhh-tamilex.github.io/Purananuru/PN325.xml?highlight=%5Bid%3DPN325%5D%20.l%3Anth-of-type(7)"><expan ref="#PN"/> 325, line 7</ref>
</cit>
<cit>
  <ref target="https://ifpindia.org/digitaldb/site/digital_tevaram/U_TEV/VMS5_041.HTM#p3"><expan ref="#Tev"/> 5.41.3.1 (trans. <abbr ref="#VMS"/>)</ref>
  <q xml:lang="ta">viḻutu cūlattaṉ</q>
  <q xml:lang="en">Civaṉ who has a trident to which fat is sticking</q>
</cit>
<note xml:lang="en">Actually the exact distinction between various kinds of animal fat on the one hand and butter or ghee on the other hand is fully dependent on context and often debatable. This can be seen from the two only early glosses available (on PN 65.2 and 150.9) which both gloss <foreign xml:lang="ta">iḻutu</foreign> with <foreign xml:lang="ta">ney</foreign>. For the time being I suggest a common sense distinction: ghee is used for cooking, but butter as a comparison for something of white colour.  
</note>
<note xml:lang="en"> Note that from the bhakti corpus onward the word <foreign xml:lang="ta">iḻutu</foreign> appears to vanish and to be replaced by <foreign xml:lang="ta">viḻutu</foreign> in the same range of meanings. This is confirmed by <abbr ref="#Cre-A"/> which does not mention <foreign xml:lang="ta">iḻutu</foreign> at all.
</note>
<note>Strangely, <foreign xml:lang="ta">viḻutu</foreign> is not taken up by the <abbr ref="#VAMTIPA"/>.
 </note></sense><sense><def xml:lang="en">ghee
</def>
<usg xml:lang="en">
</usg>
<cit source="https://uhh-tamilex.github.io/Kuruntokai/KT277.xml?id=KT277&amp;w=7,12">
    <q xml:lang="ta"><w>cem</w> <w>nel</w> <w>amalai</w> <w>veṇmai</w> <w>veḷ</w> <w><c type="geminated">ḷ</c>iḻut<c type="elided">u</c></w></q>
    <q xml:lang="en">boiled rice from red paddy [and] very white ghee</q>
            <ref target="https://uhh-tamilex.github.io/Kuruntokai/KT277.xml?highlight=%5Bid%3DKT277%5D%20.l%3Anth-of-type(2)"><expan ref="#KT"/> 277, line 2</ref>
</cit>
<cit source="https://uhh-tamilex.github.io/NalayiratTivviyapPirapantam/MuTA25.xml?id=MuTA25&amp;w=10,12">
    <q xml:lang="ta"><w>āycci</w> <w>viḻut<c type="elided">u</c></w> <w>uṇṭa</w></q>
    <q xml:lang="en">(little Kṛṣṇa) who ate the butter of the cowherdess</q>
            <ref target="https://uhh-tamilex.github.io/NalayiratTivviyapPirapantam/MuTA25.xml?highlight=%5Bid%3DMuTA25%5D%20.l%3Anth-of-type(2)"><title xml:lang="ta">Mūṉṟān Tiruvantāti</title> 25, line 2</ref>
</cit>
<note xml:lang="en">
</note></sense><sense><def xml:lang="en">butter
</def>
<usg xml:lang="en">
</usg>
<cit>
  <ref target="https://archive.org/details/Tamil-Purananuru-U-Ve-Sa-3rd-Edition-1935/page/n407/mode/2up"><expan ref="#PN"/> 150.9</ref>
  <q xml:lang="ta">iḻutiṉ aṉṉa vāl niṇam koḻum kuṟai</q>
  <q xml:lang="en">fat pieces of fat as white as butter</q>
</cit>
<note xml:lang="en">
</note></sense>
